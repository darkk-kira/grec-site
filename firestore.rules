rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Membres - Utilisateurs peuvent lire tous les profils, mais modifier seulement le leur
    match /membres/{userId} {
      allow read: if true; // Tout le monde peut voir les profils
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Admins - Seulement les admins peuvent lire/écrire
    match /admins/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Actualités - Tout le monde peut lire, seulement admins peuvent créer/modifier
    match /actualites/{articleId} {
      allow read: if true;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Galerie - Tout le monde peut lire, seulement admins peuvent créer/modifier
    match /galerie/{imageId} {
      allow read: if true;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Newsletter - Tout le monde peut s'inscrire
    match /newsletter/{email} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow create: if true;
    }

    // Contacts - Tout le monde peut envoyer, admins peuvent lire
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Chats - Utilisateurs connectés peuvent lire/écrire leurs propres messages
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }
  }
}