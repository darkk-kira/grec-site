rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'admin@grec.com';
    }

    // Membres - chacun peut gérer son propre profil, lecture publique
    match /membres/{userId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Admins - bootstrap et contrôle d'accès admin
    match /admins/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId && isAdmin();
    }

    // Actualites - lecture publique, écriture admin
    match /actualites/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Galerie - lecture publique, écriture admin
    match /galerie/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Evenements - lecture publique, écriture admin
    match /evenements/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Newsletter - inscription publique, lecture admin
    match /newsletter/{email} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contacts - message public, lecture admin
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Chats - utilisateurs connectes
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }
  }
}
